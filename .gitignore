# ==========================================
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
env/
.pytest_cache/

# ==========================================
# Node.js / TypeScript (If you used Express/Workers)
# ==========================================
node_modules/
dist/
build/
.wrangler/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ==========================================
# Databases & Logs
# ==========================================
*.sqlite
*.sqlite3
*.db
*.log
data/